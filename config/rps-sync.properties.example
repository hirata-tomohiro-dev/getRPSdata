# RPS site settings
# login URL includes the credentials required by the target site.
# Do not commit the real values. Copy this file to config/rps-sync.properties and edit it locally.
rps.loginUrl=http://10.202.xxx.xxx:13010/login/login?domain=your.domain&shain_cd=your_id&pass=your_password
rps.baseUrl=http://10.202.xxx.xxx:13010
rps.schema=KYKOWNER
rps.tableListUrl=http://10.202.xxx.xxx:13010/table/list?utf8=%E2%9C%93&pm=ent&keyword_db=&keyword_object_name=&keyword_description=&keyword_group_name=&search_condition%5Btype%5D=REFLECT&submit=%E5%85%A8%E4%BB%B6%E8%A1%A8%E7%A4%BA
rps.schemaSetPath=/schema/set_schema
rps.proxyHost=10.202.5.30
rps.proxyPort=8080
rps.sleepMillis=100
rps.connectTimeoutMillis=15000
rps.readTimeoutMillis=15000

# Output directory
result.dir=result

# PostgreSQL sync settings
pg.enabled=true
pg.host=10.205.185.138
pg.port=5432
pg.database=postgres
pg.user=postgres
pg.password=
pg.schema=public
pg.table=rps_table_inventory
pg.sslmode=disable
pg.connectTimeoutSeconds=10
pg.socketTimeoutSeconds=30
